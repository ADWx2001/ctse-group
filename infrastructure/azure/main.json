                {
                  "name": "PORT",
                  "value": "3001"
                },
                {
                  "name": "MONGODB_URI",
                  "secretRef": "mongodb-uri"
                },
                {
                  "name": "JWT_SECRET",
                  "secretRef": "jwt-secret"
                },
                {
                  "name": "JWT_EXPIRES_IN",
                  "value": "7d"
                }
              ],
              "probes": [
                {
                  "type": "Liveness",
                  "httpGet": {
                    "path": "/health",
                    "port": 3001
                  },
                  "periodSeconds": 30,
                  "failureThreshold": 3
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": 1,
            "maxReplicas": 3
          }
        }
      },
      "dependsOn": [
