              ]
            }
          },
          "registries": [
            {
              "server": "[reference(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').loginServer]",
              "username": "[listCredentials(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').username]",
              "passwordSecretRef": "acr-password"
            }
          ],
          "secrets": [
            {
              "name": "acr-password",
              "value": "[listCredentials(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').passwords[0].value]"
            },
            {
              "name": "mongodb-uri",
              "value": "[replace(if(not(equals(parameters('mongodbUri'), '')), parameters('mongodbUri'), listConnectionStrings(resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosName')), '2023-11-15').connectionStrings[0].connectionString), '/?', '/foodorder_users?')]"
            },
            {
              "name": "jwt-secret",
              "value": "[parameters('jwtSecret')]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "user-service",
              "image": "[format('{0}/food-ordering-user-service:latest', reference(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').loginServer)]",
              "resources": {
                "cpu": "[json('0.25')]",
